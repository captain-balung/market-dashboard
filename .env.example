# =====================================================================
# .env.example — 環境變數範本
# 使用方式：cp .env.example .env.local 後填入實際值
# 規則：
#   - 任何含機密的 key 一律不可帶 NEXT_PUBLIC_ 前綴（否則會打進前端 bundle）
#   - 機密一律 server-only（API route / server component / cron）
#   - 真實的 .env.local 已在 .gitignore，不會被 commit
# =====================================================================

# ---------- Supabase ----------
# Public（可暴露在前端）
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only（高權限，絕不可走前端）
SUPABASE_SERVICE_ROLE_KEY=

# ---------- 價格與新聞資料源（皆 server-only）----------
COINGECKO_API_KEY=
FINNHUB_API_KEY=
CRYPTOPANIC_API_KEY=
MARKETAUX_API_KEY=
FRED_API_KEY=

# ---------- AI 摘要（server-only）----------
ANTHROPIC_API_KEY=

# ---------- admin 管理介面（server-only）----------
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ---------- Vercel Cron 觸發驗證（server-only）----------
# 任意長字串，建議 openssl rand -hex 32
CRON_SECRET=
